{
  "name": "hytrack-server",
  "version": "1.0.0",
  "description": "hytrack backend - Node.js + Express + PostgreSQL",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "db:init": "node -e \"const { initDatabase } = require('./db/init'); initDatabase().then(() => process.exit(0)).catch((err) => { console.error(err.message); process.exit(1); });\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
